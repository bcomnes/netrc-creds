{
  "name": "netrc-creds",
  "version": "3.0.2",
  "private": true,
  "description": "Set up netrc creds in Github Actions",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "run-s test:*",
    "test:neostandard": "eslint .",
    "test:tsc": "tsc",
    "preversion": "releasearoni preversion",
    "version": "npm run build && releasearoni version --add dist",
    "prepublishOnly": "releasearoni",
    "build": "rm -rf dist && esbuild index.js --bundle --platform=node --target=node24 --format=esm --sourcemap=external --outdir=dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bcomnes/netrc-creds.git"
  },
  "keywords": [
    "github",
    "actions",
    "netrc"
  ],
  "author": "Bret Comnes <bcomnes@gmail.com> (https://bret.io/)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bcomnes/netrc-creds/issues"
  },
  "homepage": "https://github.com/bcomnes/netrc-creds#readme",
  "dependencies": {
    "@actions/core": "3.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@voxpelli/tsconfig": "^16.0.0",
    "esbuild": "^0.27.0",
    "neostandard": "^0.13.0",
    "npm-run-all2": "^8.0.1",
    "releasearoni": "^0.1.12",
    "typescript": "~5.9.2"
  }
}
